# =====================================================================
# Zensil Ops — environment TEMPLATE (safe to commit). Copy values into:
#   .env.local   (web app, repo root — gitignored; also read by docker compose)
#   etl/.env     (pipelines — gitignored)
# and add them as GitHub Actions Secrets for the scheduled ETL.
# Never put real secrets in this file.
# =====================================================================

# ---- Dashboard login (self-contained session auth) ----
APP_AUTH_EMAIL=office@zensil.in
APP_AUTH_PASSWORD=change-me
APP_AUTH_SECRET=change-me-to-a-long-random-string

# ---- Warehouse (dashboard reads this server-side; ETL writes to it) ----
DATABASE_URL=postgresql://user:password@host/db

# ---- Optional: real Claude answers in /api/claude ----
ANTHROPIC_API_KEY=

# ---- Amazon SP-API (orders / inventory / returns) ----
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV
SPAPI_CLIENT_ID=
SPAPI_CLIENT_SECRET=
SPAPI_REFRESH_TOKEN=

# ---- Amazon Ads API (Direct Advertiser approval required) ----
ADS_CLIENT_ID=
ADS_CLIENT_SECRET=
ADS_REFRESH_TOKEN=
ADS_PROFILE_ID=

# ---- Flipkart Marketplace API ----
FLIPKART_APP_ID=
FLIPKART_APP_SECRET=

# ---- Shopify Admin API (token must start with shpat_) ----
SHOPIFY_STORE_DOMAIN=zensil-in.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# ---- Alerting (pick webhook and/or email) ----
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
RESEND_API_KEY=
